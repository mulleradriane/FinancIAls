# Backend
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/financials
SECRET_KEY=           # Required. Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7 days
INVITE_CODE=          # Optional. If set, users need this code to register.

# Frontend (Vite)
VITE_API_URL=http://127.0.0.1:8000  # URL of the FastAPI backend
